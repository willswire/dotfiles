{
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "soft_wrap": "editor_width",
  "hard_tabs": false,
  "remove_trailing_whitespace_on_save": false,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Macchiato"
  },
  "tabs": {
    "git_status": true
  },
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/zarf-dev/zarf/main/zarf.schema.json": [
              "/*zarf.yaml"
            ],
            "https://raw.githubusercontent.com/defenseunicorns/maru-runner/main/tasks.schema.json": [
              "/*tasks.yaml",
              "/tasks/*.yaml"
            ],
            "https://raw.githubusercontent.com/defenseunicorns/uds-cli/main/uds.schema.json": [
              "/*uds-bundle.yaml"
            ]
          }
        }
      }
    }
  },
  "calls": {
    "mute_on_join": true
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/helmfile.d/**/*.yaml"
    ],
    "COBOL": ["*.pco"],
    "JSONC": ["*.json5"]
  },
  "languages": {
    "JSONC": {
      "format_on_save": "off"
    },
    "TypeScript": {
      "format_on_save": "off"
    }
  }
}
